# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — dependency resolver
#   Uses uv to compile a deterministic lockfile and then install into /app/.venv.
#   Kept separate so the layer is re-used on code-only changes.
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.14-slim AS deps

# Install uv (fast Python package manager)
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy only the dependency manifest — cache busted only when deps change
COPY pyproject.toml ./

# Create the virtualenv and install all production dependencies
RUN uv venv .venv && \
    uv pip install --python .venv/bin/python -e ".[all]" || \
    uv pip install --python .venv/bin/python .


# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — runtime image
#   Copies only the venv and source; no build tools in the final layer.
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.14-slim AS runtime

WORKDIR /app

# Re-create the non-root user for security
RUN addgroup --system app && adduser --system --ingroup app app

# Copy the pre-built virtualenv from the deps stage
COPY --from=deps /app/.venv /app/.venv

# Copy application source
COPY src/ ./src/
COPY pyproject.toml ./

# Make the venv's Python the default
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH="/app/src" \
    PYTHONUNBUFFERED=1

# ── Runtime configuration (override with env vars or .env mount) ─────────────
# LLM / Puter
ENV PUTER_MODEL="" \
    PUTER_AUTH_TOKEN="" \
    PUTER_API_BASE=""

# Stripe
ENV STRIPE_SECRET_KEY="" \
    STRIPE_PUBLISHABLE_KEY="" \
    STRIPE_WEBHOOK_SECRET=""

# Server
ENV HOST="0.0.0.0" \
    PORT="9999"

EXPOSE 9999

# Drop to non-root
USER app

# Entry point: start the swarm server with uvicorn
CMD ["python", "-m", "uvicorn", "agent_puter.swarm.main:app", \
     "--host", "0.0.0.0", "--port", "9999", "--proxy-headers"]
