########################################################################################
########################## Puter.js & LiteLLM configuration ############################
########################################################################################
PUTER_AUTH_TOKEN=YOUR_PUTER_AUTH_TOKEN
PUTER_API_BASE=https://api.puter.com/puterai/openai/v1
PUTER_MODEL=openai/claude-sonnet-4-5

########################################################################################
############################## Stripe configuration ####################################
########################################################################################
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

########################################################################################
######################### API URL FOR FROM BACKEND #####################################
########################################################################################
# In production this would use your deployed endpoints url but in development this is default
NEXT_PUBLIC_API_URL=http://localhost:9999
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
